@page "/"
@rendermode InteractiveServer
@using AlmoxarifadoCGH.Web.Services
@inject EstoqueService EstoqueService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Large" Class="mr-2 mb-n1" />
        Painel de Operações
    </MudText>

    <MudGrid>
        @* CARD: ESTOQUE BAIXO *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="4" Class="pa-4 d-flex flex-column h-100" Style="cursor: pointer; border-left: 6px solid #f44336;" @onclick='() => Nav.NavigateTo("/dashboard/detalhes/estoque")'>
                <div class="d-flex justify-space-between align-start mb-4">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default" Class="text-uppercase fw-bold">Estoque Crítico</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Dark">@qtdEstoqueBaixo</MudText>
                    </div>
                    <MudAvatar Color="Color.Error" Variant="Variant.Filled" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" />
                    </MudAvatar>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Error">Clique para ver os itens a repor</MudText>
            </MudPaper>
        </MudItem>

        @* CARD: ATRASOS *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="4" Class="pa-4 d-flex flex-column h-100" Style="cursor: pointer; border-left: 6px solid #ff9800;" @onclick='() => Nav.NavigateTo("/dashboard/detalhes/atrasos")'>
                <div class="d-flex justify-space-between align-start mb-4">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default" Class="text-uppercase fw-bold">Atrasos (> 12h)</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Dark">@qtdAtrasados</MudText>
                    </div>
                    <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" />
                    </MudAvatar>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Warning">Kits que não regressaram à base</MudText>
            </MudPaper>
        </MudItem>

        @* CARD: SAÍDAS DO TURNO *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="4" Class="pa-4 d-flex flex-column h-100" Style="cursor: pointer; border-left: 6px solid #4caf50;" @onclick='() => Nav.NavigateTo("/dashboard/detalhes/turno")'>
                <div class="d-flex justify-space-between align-start mb-4">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default" Class="text-uppercase fw-bold">Saídas no Turno</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Dark">@qtdSaidasTurno</MudText>
                    </div>
                    <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.FlightTakeoff" />
                    </MudAvatar>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Success">Movimentações nas últimas 12h</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int qtdEstoqueBaixo;
    private int qtdAtrasados;
    private int qtdSaidasTurno;

    protected override async Task OnInitializedAsync()
    {
        qtdEstoqueBaixo = await EstoqueService.ContarItensEstoqueBaixoAsync();
        qtdAtrasados = await EstoqueService.ContarEquipamentosAtrasadosAsync();
        qtdSaidasTurno = await EstoqueService.ContarSaidasDoTurnoAsync();
    }
}