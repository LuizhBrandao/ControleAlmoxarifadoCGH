@page "/catalogo/{CatalogoId:int}/patrimonios"
@rendermode InteractiveServer
@using Almoxarifado.Domain.Entities
@using Almoxarifado.Domain.Enums
@using AlmoxarifadoCGH.Web.Services
@inject EstoqueService EstoqueService
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4">Patrimônios: @catalogoNome</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick='() => Nav.NavigateTo("/catalogo")'>
            Voltar ao Catálogo
        </MudButton>
    </div>

    <MudPaper Elevation="3" Class="pa-4 mb-6">
        <MudGrid Class="align-end">
            <MudItem xs="12" md="9">
                <MudTextField @bind-Value="novoSerial" Label="Cadastrar Novo Número de Série" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" OnClick="AdicionarPatrimonio">
                    Adicionar
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable Items="@equipamentos" Hover="true" Elevation="3">
        <HeaderContent>
            <MudTh>Número de Série (Patrimônio)</MudTh>
            <MudTh>Status Atual</MudTh>
            <MudTh>Ações de Manutenção</MudTh>
        </HeaderContent>
        <RowTemplate Context="eq">
            <MudTd DataLabel="Número de Série">
                @if (equipamentoEditandoId == eq.Id)
                {
                    <div class="d-flex align-center gap-2">
                        <MudTextField @bind-Value="serialEmEdicao" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" OnClick="() => SalvarEdicao(eq.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="CancelarEdicao" />
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.body1"><b>@eq.NumeroSerie</b></MudText>
                }
            </MudTd>

            <MudTd DataLabel="Status Atual">
                <MudChip T="string" Color="@GetStatusColor(eq.Status)" Size="Size.Small">@eq.Status.ToString()</MudChip>
            </MudTd>

            <MudTd DataLabel="Ações de Manutenção">
                <div class="d-flex gap-2 align-center">
                    <MudSelect T="StatusEquipamento" Value="@eq.Status" ValueChanged="@((StatusEquipamento s) => MudarStatus(eq.Id, s))" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="width: 150px;">
                        @foreach (var status in Enum.GetValues<StatusEquipamento>())
                        {
                            <MudSelectItem T="StatusEquipamento" Value="@status">@status.ToString()</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTooltip Text="Corrigir Digitação">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => IniciarEdicao(eq)" />
                    </MudTooltip>

                    <MudTooltip Text="Excluir Definitivamente">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => ExcluirEquipamento(eq)" />
                    </MudTooltip>
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    [Parameter] public int CatalogoId { get; set; }

    private List<Equipamento> equipamentos = new();
    private string catalogoNome = "";
    private string novoSerial = "";

    // Variáveis para controlar a edição em linha
    private int equipamentoEditandoId = 0;
    private string serialEmEdicao = "";

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        var catalogo = await EstoqueService.BuscarCatalogoPorIdAsync(CatalogoId);
        if (catalogo != null) catalogoNome = catalogo.Nome;

        equipamentos = await EstoqueService.ListarEquipamentosPorCatalogoAsync(CatalogoId);
    }

    private async Task AdicionarPatrimonio()
    {
        if (string.IsNullOrWhiteSpace(novoSerial)) return;
        try
        {
            var novoEquipamento = new Equipamento { CatalogoId = CatalogoId, NumeroSerie = novoSerial.Trim(), Status = StatusEquipamento.Disponivel };
            await EstoqueService.AdicionarEquipamentoAsync(novoEquipamento);
            novoSerial = "";
            await CarregarDados();
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", ex.Message); }
    }

    // O MudSelect agora envia diretamente o Enum, o que deixa o código mais limpo
    private async Task MudarStatus(int equipamentoId, StatusEquipamento novoStatus)
    {
        await EstoqueService.AtualizarStatusEquipamentoAsync(equipamentoId, novoStatus);
        await CarregarDados();
    }

    private void IniciarEdicao(Equipamento eq)
    {
        equipamentoEditandoId = eq.Id;
        serialEmEdicao = eq.NumeroSerie;
    }

    private void CancelarEdicao()
    {
        equipamentoEditandoId = 0;
        serialEmEdicao = "";
    }

    private async Task SalvarEdicao(int equipamentoId)
    {
        if (string.IsNullOrWhiteSpace(serialEmEdicao)) return;
        try
        {
            await EstoqueService.AtualizarNumeroSerieEquipamentoAsync(equipamentoId, serialEmEdicao);
            CancelarEdicao();
            await CarregarDados();
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", ex.Message); }
    }

    private async Task ExcluirEquipamento(Equipamento eq)
    {
        bool confirmacao = await JS.InvokeAsync<bool>("confirm", $"Tem certeza que deseja APAGAR o patrimônio '{eq.NumeroSerie}'?");
        if (confirmacao)
        {
            try
            {
                await EstoqueService.ExcluirEquipamentoBlindadoAsync(eq.Id);
                await CarregarDados();
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", ex.Message);
            }
        }
    }

    // Método para mapear a cor do MudChip baseada no Status
    private Color GetStatusColor(StatusEquipamento status)
    {
        return status switch
        {
            StatusEquipamento.Disponivel => Color.Success,
            StatusEquipamento.Emprestado => Color.Warning,
            StatusEquipamento.Manutencao => Color.Error,
            _ => Color.Default
        };
    }
}