@page "/historico"
@rendermode InteractiveServer
@using Almoxarifado.Domain.Entities
@using Almoxarifado.Domain.Enums
@using AlmoxarifadoCGH.Web.Services
@inject EstoqueService EstoqueService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4"><i class="bi bi-clock-history me-2"></i>Histórico de Movimentações</MudText>
    </div>

    <MudTable Items="@listaMovimentacoes" Hover="true" Elevation="3" Filter="new Func<Movimentacao, bool>(FilterFunc)">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Buscar por série, item ou responsável..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>Data/Hora</MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh>Agente / Operação</MudTh>
            <MudTh>Item</MudTh>
            <MudTh>Patrimônio (Série)</MudTh>
            <MudTh>Contexto / Responsável</MudTh>
        </HeaderContent>

        <RowTemplate Context="m">
            <MudTd DataLabel="Data/Hora">@m.DataHora.ToString("dd/MM/yyyy HH:mm")</MudTd>

            <MudTd DataLabel="Tipo">
                <MudChip T="string" Color="@(m.Tipo == TipoMovimentacao.Saida ? Color.Warning : Color.Info)" Size="Size.Small">
                    @m.Tipo.ToString()
                </MudChip>
            </MudTd>

            <MudTd DataLabel="Agente / Operação">
                @(m.Agente != null ? m.Agente.Nome : "Operação de Kit")
            </MudTd>

            <MudTd DataLabel="Item">@(m.Catalogo != null ? m.Catalogo.Nome : "N/A")</MudTd>

            <MudTd DataLabel="Patrimônio">
                @if (m.Equipamento != null)
                {
                    <MudText Typo="Typo.body2" Class="fw-bold">@m.Equipamento.NumeroSerie</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Surface">Consumo (Qtd: @m.Quantidade)</MudText>
                }
            </MudTd>

            <MudTd DataLabel="Contexto / Responsável">@m.NomeAlmoxarife</MudTd>
        </RowTemplate>

        <PagerContent>
            <MudTablePager InfoFormat="{first_item}-{last_item} de {all_items}" RowsPerPageString="Itens por página:" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private List<Movimentacao> listaMovimentacoes = new();
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        listaMovimentacoes = await EstoqueService.ListarHistoricoAsync();
    }

    // Função que faz a barra de pesquisa funcionar em tempo real
    private bool FilterFunc(Movimentacao element)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;

        if (element.Equipamento?.NumeroSerie.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (element.Catalogo?.Nome.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (element.NomeAlmoxarife?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;

        return false;
    }
}