@page "/gestao-mochilas"
@using AlmoxarifadoCGH.Web.Services
@using Almoxarifado.Domain.Entities
@using Almoxarifado.Domain.Enums
@using Almoxarifado.Domain.ValueObjects
@inject EstoqueService EstoqueService
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4">Gestão de Mochilas (Kits)</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AbrirDialogoNovaMochila">
            Nova Mochila
        </MudButton>
    </div>

    <MudTable Items="@mochilas" Hover="true" Elevation="3">
        <HeaderContent>
            <MudTh>Número</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Operação Atual</MudTh>
            <MudTh>Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Número">Mochila @context.Numero</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status.ToString()</MudChip>
            </MudTd>
            <MudTd DataLabel="Operação Atual">
                @if (context.OperacaoAtual != null)
                {
                    <MudText Typo="Typo.body2">@context.OperacaoAtual.Turno - @context.OperacaoAtual.Dupla</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Surface">Nenhuma</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Ações">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" OnClick="@(() => AbrirDialogoMontarKit(context.Id))">Montar Kit</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<Mochila> mochilas = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        mochilas = await EstoqueService.ListarTodasMochilasAsync();
        StateHasChanged();
    }

    private async Task AbrirDialogoNovaMochila()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<NovaMochilaDialog>("Adicionar Nova Mochila", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await CarregarDados(); // Recarrega a tabela se uma mochila foi adicionada
        }
    }

    private Color GetStatusColor(StatusMochila status)
    {
        return status switch
        {
            StatusMochila.Disponivel => Color.Success,
            StatusMochila.EmUso => Color.Warning,
            StatusMochila.Manutencao => Color.Error,
            _ => Color.Default
        };
    }
    private async Task AbrirDialogoMontarKit(int mochilaId)
    {
        // Passa o ID da mochila específica para dentro do Dialog
        var parameters = new DialogParameters { ["MochilaId"] = mochilaId };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<MontarKitDialog>("Montar Kit da Mochila", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await CarregarDados(); // Atualiza a tela após montar
        }
    }

}