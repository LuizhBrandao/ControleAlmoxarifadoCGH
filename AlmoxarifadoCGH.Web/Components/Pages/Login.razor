@page "/login"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using AlmoxarifadoCGH.Web.Security
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-lg mt-5 border-top border-primary border-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-box-seam fs-1 text-primary"></i>
                        <h3 class="fw-bold mt-2">Almoxarifado LATAM</h3>
                        <p class="text-muted">Identificação do Operador</p>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="inputNome" placeholder="Seu Nome"
                               @bind="nomeUsuario" @bind:event="oninput" @onkeyup="VerificarEnter" autofocus />
                        <label for="inputNome">Nome ou Credencial</label>
                    </div>

                    <div class="d-grid gap-2 mt-4 mb-0">
                        <button class="btn btn-primary btn-lg" @onclick="Autenticar" disabled="@string.IsNullOrWhiteSpace(nomeUsuario)">
                            Iniciar Turno
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string nomeUsuario = "";

    private async Task Autenticar()
    {
        if (string.IsNullOrWhiteSpace(nomeUsuario)) return;

        var customAuthStateProvider = (CustomAuthStateProvider)AuthStateProvider;
        await customAuthStateProvider.AtualizarEstadoAutenticacao(nomeUsuario.Trim());

        Nav.NavigateTo("/", true);
    }

    private async Task VerificarEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Autenticar();
        }
    }
}