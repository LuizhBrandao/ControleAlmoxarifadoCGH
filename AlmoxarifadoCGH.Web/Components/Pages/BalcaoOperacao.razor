@page "/balcao"
@rendermode InteractiveServer
@using AlmoxarifadoCGH.Web.Services
@using Almoxarifado.Domain.Entities
@using Almoxarifado.Domain.ValueObjects
@inject EstoqueService EstoqueService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-6">Balcão de Operação</MudText>

    <MudGrid>
        @* ========================================================= *@
        @* CARD DE SAÍDA (ENTREGAR MOCHILA)                          *@
        @* ========================================================= *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Primary">Registrar Saída (Check-out)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSelect T="int" @bind-Value="mochilaSaidaId" Label="Mochila Disponível" Variant="Variant.Outlined" Class="mb-4" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="int" Value="0">-- Selecione uma mochila --</MudSelectItem>
                        @foreach (var m in mochilasDisponiveis)
                        {
                            <MudSelectItem T="int" Value="@m.Id">Mochila @m.Numero</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="string" @bind-Value="turnoSelecionado" Label="Turno" Variant="Variant.Outlined" Class="mb-4" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="string" Value="@("")">-- Selecione o turno --</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Manhã")">Manhã</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Tarde")">Tarde</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Noite")">Noite</MudSelectItem>
                    </MudSelect>

                    <div class="d-flex gap-4 mb-4">
                        <MudSelect T="int" @bind-Value="agente1Id" Label="Agente 1 (Responsável)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="int" Value="0">-- Selecione --</MudSelectItem>
                            @foreach (var a in agentesCadastrados)
                            {
                                <MudSelectItem T="int" Value="@a.Id">@a.Nome</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="int" @bind-Value="agente2Id" Label="Agente 2 (Apoio)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="int" Value="0">-- Selecione --</MudSelectItem>
                            @foreach (var a in agentesCadastrados)
                            {
                                <MudSelectItem T="int" Value="@a.Id">@a.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                </MudCardContent>
                <MudCardActions>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" OnClick="RegistrarSaida"
                               Disabled="@(mochilaSaidaId == 0 || string.IsNullOrWhiteSpace(turnoSelecionado) || agente1Id == 0 || agente2Id == 0)">
                        Entregar Kit
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        @* ========================================================= *@
        @* CARD DE DEVOLUÇÃO (RECEBER MOCHILA)                       *@
        @* ========================================================= *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Registrar Devolução (Check-in)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSelect T="int" @bind-Value="mochilaDevolucaoId" Label="Mochila Em Uso" Variant="Variant.Outlined" Class="mb-4" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="int" Value="0">-- Selecione uma mochila --</MudSelectItem>
                        @foreach (var m in mochilasEmUso)
                        {
                            <MudSelectItem T="int" Value="@m.Id">Mochila @m.Numero</MudSelectItem>
                        }
                    </MudSelect>
                    <MudAlert Severity="Severity.Info" Class="mt-4">
                        Verifique se todos os equipamentos estão dentro da mochila antes de confirmar a devolução.
                    </MudAlert>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Color="Color.Secondary" Variant="Variant.Filled" FullWidth="true" OnClick="RegistrarDevolucao" Disabled="@(mochilaDevolucaoId == 0)">
                        Confirmar Devolução
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    // Variáveis de Saída
    private int mochilaSaidaId = 0;
    private string turnoSelecionado = "";
    private int agente1Id = 0;
    private int agente2Id = 0;

    // Variáveis de Devolução
    private int mochilaDevolucaoId = 0;

    // Listas de Dados
    private List<Mochila> mochilasDisponiveis = new();
    private List<Mochila> mochilasEmUso = new();
    private List<Agente> agentesCadastrados = new();

    protected override async Task OnInitializedAsync()
    {
        // Ao abrir a tela, já puxa todos os agentes cadastrados para preencher os selects
        agentesCadastrados = await EstoqueService.ListarAgentesAsync();
        await CarregarDadosAsync();
    }

    private async Task CarregarDadosAsync()
    {
        mochilasDisponiveis = await EstoqueService.ListarMochilasPorStatusAsync(StatusMochila.Disponivel);
        mochilasEmUso = await EstoqueService.ListarMochilasPorStatusAsync(StatusMochila.EmUso);
        StateHasChanged();
    }

    private async Task RegistrarSaida()
    {
        try
        {
            // Passa os dois IDs selecionados para o backend resolver a dupla
            await EstoqueService.EntregarMochilaAsync(mochilaSaidaId, turnoSelecionado, agente1Id, agente2Id);
            Snackbar.Add("Kit entregue com sucesso!", Severity.Success);

            // Limpa o formulário
            mochilaSaidaId = 0;
            turnoSelecionado = "";
            agente1Id = 0;
            agente2Id = 0;

            await CarregarDadosAsync();
        }
        catch (Exception ex)
        {
            string erroReal = ex.InnerException != null ? ex.InnerException.Message : ex.Message;
            Snackbar.Add(erroReal, Severity.Error);
        }
    }

    private async Task RegistrarDevolucao()
    {
        try
        {
            await EstoqueService.DevolverMochilaAsync(mochilaDevolucaoId);
            Snackbar.Add("Mochila devolvida com sucesso!", Severity.Success);

            mochilaDevolucaoId = 0;
            await CarregarDadosAsync();
        }
        catch (Exception ex)
        {
            string erroReal = ex.InnerException != null ? ex.InnerException.Message : ex.Message;
            Snackbar.Add(erroReal, Severity.Error);
        }
    }
}