@page "/catalogo"
@rendermode InteractiveServer
@using Almoxarifado.Domain.Entities
@using AlmoxarifadoCGH.Web.Services
@inject EstoqueService EstoqueService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" Class="mr-2 mb-n1" />
            Catálogo de Materiais
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NovoItem">
            Adicionar Item
        </MudButton>
    </div>

    @if (exibirFormulario)
    {
        <MudPaper Elevation="3" Class="pa-4 mb-6" Style="border-top: 4px solid #594ae2;">
            <MudText Typo="Typo.h6" Class="mb-4">@(model.Id == 0 ? "Adicionar Novo Item" : "Editar Item")</MudText>

            <EditForm Model="model" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <MudGrid Class="align-end">
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="model.Nome" For="@(() => model.Nome)" @bind-Value:after="VerificarSeExiste" Label="Nome do Item" Variant="Variant.Outlined" Placeholder="Ex: Bobina" Margin="Margin.Dense" />
                        @if (itemJaExiste)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1 d-block">
                                <b><MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" Style="vertical-align: text-bottom;" />A Qtd será somada.</b>
                            </MudText>
                        }
                    </MudItem>

                    <MudItem xs="12" md="2">
                        <MudSelect T="bool" @bind-Value="model.IsConsumivel" Label="Tipo" Disabled="@(itemJaExiste || model.Id != 0)" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="bool" Value="false">Equipamento</MudSelectItem>
                            <MudSelectItem T="bool" Value="true">Consumível</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="3">
                        @if (!model.IsConsumivel)
                        {
                            <MudTextField @bind-Value="model.Descricao" For="@(() => model.Descricao)" Label="Nº Patrimônio/Série" Variant="Variant.Outlined" Placeholder="Ex: CGH-001" Margin="Margin.Dense" />
                        }
                        else
                        {
                            <MudTextField @bind-Value="model.Descricao" For="@(() => model.Descricao)" Label="Observação" Variant="Variant.Outlined" Placeholder="Ex: Caixa c/ 50" Disabled="@itemJaExiste" Margin="Margin.Dense" />
                        }
                    </MudItem>

                    <MudItem xs="12" md="2">
                        @if (model.IsConsumivel)
                        {
                            <MudNumericField @bind-Value="model.EstoqueAtual" For="@(() => model.EstoqueAtual)" Label="@(itemJaExiste ? "Entrada" : "Qtd")" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                            @if (itemJaExiste)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1 d-block">Atual: @estoqueNoBanco</MudText>
                            }
                        }
                    </MudItem>

                    <MudItem xs="12" md="2">
                        @if (model.IsConsumivel)
                        {
                            <MudNumericField @bind-Value="model.EstoqueMinimo" For="@(() => model.EstoqueMinimo)" Label="Mínimo" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                        }
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="() => exibirFormulario = false">Cancelar</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success">Gravar</MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    }

    <MudTable Items="@listaItens" Hover="true" Elevation="3" Striped="true">
        <HeaderContent>
            <MudTh>Nome do Item</MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh>Detalhe (Patrimônio/Obs)</MudTh>
            <MudTh>Estoque</MudTh>
            <MudTh>Ações</MudTh>
        </HeaderContent>
        <RowTemplate Context="item">
            <MudTd DataLabel="Nome"><MudText Typo="Typo.body1" Class="fw-bold">@item.Nome</MudText></MudTd>
            <MudTd DataLabel="Tipo">
                <MudChip T="string" Color="@(item.IsConsumivel ? Color.Dark : Color.Primary)" Size="Size.Small">
                    @(item.IsConsumivel ? "Consumível" : "Equipamento")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Detalhe">
                @if (item.IsConsumivel)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@(string.IsNullOrEmpty(item.Descricao) ? "-" : item.Descricao)</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Múltiplos Patrimônios</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Estoque">
                @if (item.IsConsumivel)
                {
                    <div class="d-flex align-center">
                        <MudText Typo="Typo.body1" Class="@(item.EstoqueAtual <= item.EstoqueMinimo ? "text-danger fw-bold" : "")">@item.EstoqueAtual</MudText>
                        @if (item.EstoqueAtual <= item.EstoqueMinimo)
                        {
                            <MudTooltip Text="Estoque Crítico!">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" Class="ml-2" />
                            </MudTooltip>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.body1" Class="fw-bold">@(item.Equipamentos?.Count ?? 0)</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Ações">
                <div class="d-flex gap-2">
                    @if (!item.IsConsumivel)
                    {
                        <MudTooltip Text="Gerir Patrimônios (Séries)">
                            <MudIconButton Icon="@Icons.Material.Filled.FormatListNumbered" Color="Color.Info" Size="Size.Small" OnClick="@(() => Nav.NavigateTo($"/catalogo/{item.Id}/patrimonios"))" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => Editar(item)" />
                    </MudTooltip>
                    <MudTooltip Text="Excluir">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Apagar(item)" />
                    </MudTooltip>
                </div>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager InfoFormat="{first_item}-{last_item} de {all_items}" RowsPerPageString="Itens por página:" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private List<Catalogo> listaItens = new();
    private Catalogo model = new();
    private bool exibirFormulario = false;
    private bool itemJaExiste = false;
    private int estoqueNoBanco = 0;
    private bool modoEdicaoTabela = false;

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados() => listaItens = await EstoqueService.ListarCatalogoAsync();

    private async Task Guardar()
    {
        try
        {
            if (itemJaExiste && model.IsConsumivel)
            {
                model.EstoqueAtual += estoqueNoBanco;
            }

            if (!model.IsConsumivel && model.EstoqueAtual == 0)
            {
                model.EstoqueAtual = 1;
            }

            await EstoqueService.SalvarItemCatalogoAsync(model);
            Snackbar.Add("Item gravado com sucesso no catálogo!", Severity.Success);
            exibirFormulario = false;
            await CarregarDados();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task VerificarSeExiste()
    {
        if (modoEdicaoTabela || string.IsNullOrWhiteSpace(model.Nome))
        {
            itemJaExiste = false;
            return;
        }

        var existente = await EstoqueService.BuscarItemPorNomeAsync(model.Nome);
        if (existente != null)
        {
            itemJaExiste = true;
            estoqueNoBanco = existente.EstoqueAtual;

            model.Id = existente.Id;
            model.IsConsumivel = existente.IsConsumivel;
            model.EstoqueMinimo = existente.EstoqueMinimo;
            model.EstoqueAtual = 0;
            model.Descricao = existente.IsConsumivel ? existente.Descricao : "";
        }
        else
        {
            itemJaExiste = false;
            model.Id = 0;
        }
    }

    private void Editar(Catalogo i)
    {
        model = i;
        modoEdicaoTabela = true;
        itemJaExiste = false;

        if (!model.IsConsumivel)
        {
            model.Descricao = "";
        }

        exibirFormulario = true;
    }

    private void NovoItem()
    {
        model = new Catalogo { IsConsumivel = true }; // Por defeito, abre como Consumível
        itemJaExiste = false;
        modoEdicaoTabela = false;
        exibirFormulario = true;
    }

    private async Task Apagar(Catalogo item)
    {
        bool confirmacao = await JS.InvokeAsync<bool>("confirm", $"Tem a certeza que deseja apagar '{item.Nome}' do catálogo?");
        if (confirmacao)
        {
            bool sucesso = await EstoqueService.ExcluirItemCatalogoAsync(item.Id);
            if (sucesso)
            {
                Snackbar.Add("Item excluído com sucesso.", Severity.Success);
                await CarregarDados();
            }
            else
            {
                Snackbar.Add("Acesso Negado: Não é possível apagar! Este item já possui registos no Histórico de Movimentações.", Severity.Error);
            }
        }
    }
}